{
  "schema_version": 1,
  "id": "gemini",
  "sort_order": 30,
  "name": "Gemini CLI",
  "icon": {
    "view_box": "0 0 24 24",
    "color": "#3b82f6",
    "paths": [
      { "d": "M12 2c0 5.523 4.477 10 10 10-5.523 0-10 4.477-10 10 0-5.523-4.477-10-10-10 5.523 0 10-4.477 10-10z" },
      { "d": "M19 3c0 2.21-1.79 4-4 4 2.21 0 4 1.79 4 4 0-2.21 1.79-4 4-4-2.21 0-4-1.79-4-4z", "opacity": 0.7 }
    ]
  },
  "config_dir": "~/.gemini",
  "user_agent": ["geminicli", "gemini-cli"],
  "protocols": ["gemini_generate_content"],
  "features": {
    "provider_config": {
      "enabled": true,
      "operations": [
        {
          "id": "set-token",
          "op": "set",
          "file": ".env",
          "format": "env",
          "path": ["GEMINI_API_KEY"],
          "value": "{target.token}"
        },
        {
          "id": "set-endpoint",
          "op": "set",
          "file": ".env",
          "format": "env",
          "path": ["GOOGLE_GEMINI_BASE_URL"],
          "value": "{target.endpoint}"
        },
        {
          "id": "set-auth-type",
          "op": "set",
          "file": "settings.json",
          "format": "json",
          "path": ["security", "auth", "selectedType"],
          "value": "gemini-api-key"
        }
      ]
    },
    "global_preset": {
      "enabled": true,
      "file": "settings.json",
      "format": "json"
    },
    "profiles": { "enabled": false },
    "official_login": {
      "enabled": true,
      "operations": [
        {
          "id": "replace-gemini-oauth",
          "op": "replace_file",
          "file": "oauth_creds.json",
          "content_from": { "file_id": "gemini_oauth" }
        },
        {
          "id": "replace-gemini-accounts",
          "op": "replace_file",
          "file": "google_accounts.json",
          "content_from": { "file_id": "gemini_accounts" }
        },
        {
          "id": "set-auth-type",
          "op": "set_field",
          "file": "settings.json",
          "format": "json",
          "path": ["security", "auth", "selectedType"],
          "value": "oauth-personal"
        }
      ]
    },
    "model_mapping": { "enabled": true },
    "token_usage": { "enabled": true },
    "skills": { "enabled": true, "directory": "skills" },
    "mcp": {
      "enabled": true,
      "file": "settings.json",
      "format": "json",
      "servers_path": ["mcpServers"]
    },
    "sessions": { "enabled": true, "adapter": "gemini" },
    "plugins": { "enabled": false },
    "prompts": { "enabled": true, "file": "GEMINI.md" }
  }
}
